# Production environment (copy to .env.production — never commit).
# Setup and deploy procedure: docs/deployment.md
# Reuse MAILGUN_* from songbook-oc .env.production on your machine.

# Password here must match PG_PASSWORD when running deploy/setup-postgres-apt.sh
DATABASE_URL="ecto://biblereader:CHANGE_ME@127.0.0.1:5432/biblereader_prod"
SECRET_KEY_BASE="CHANGE_ME"
PHX_HOST="biblereader.upscale-automation.com"
PORT=4000
POOL_SIZE=10

MAILGUN_API_KEY="..."
MAILGUN_DOMAIN="mg.upscale-automation.com"
# Host only (same as songbook-oc) is fine — runtime.exs appends /v3 for Swoosh.
MAILGUN_BASE_URL="https://api.eu.mailgun.net"
MAIL_FROM="BibleReader <postmaster@mg.upscale-automation.com>"
